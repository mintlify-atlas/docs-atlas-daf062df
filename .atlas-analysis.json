  "keyFeatures": [
    "Adversarially balanced dataset generation for confound-free analysis",
    "GPT-2 fine-tuning on tool-calling decisions",
    "Activation patching for causal head importance",
    "Direct logit attribution (DLA) for output contribution analysis",
    "Sparse autoencoder (SAE) feature analysis",
    "Circuit discovery and ablation studies",
    "Attention pattern visualization and analysis",
    "Training dynamics tracking",
    "Comprehensive robustness testing"
  ],
  "publicApiSurface": [
    "generate_dataset() - Generate adversarially balanced synthetic dataset",
    "run_pipeline.py - Main orchestrator for all experiment phases",
    "run_activation_patching() - Identify causally important attention heads",
    "compute_dla() - Direct logit attribution analysis",
    "analyze_layer() - SAE feature analysis for interpretability",
    "identify_circuit_heads() - Synthesize circuit from patching and DLA",
    "ablate_circuit() - Test circuit necessity",
    "ablate_non_circuit() - Test circuit sufficiency",
    "Trainer - Fine-tuning loop with mixed precision",
    "evaluate_test_set() - Comprehensive model evaluation"
  ]
